{
  "manifest_version": 3,
  "name": "חוסם פרסומות בגוגל ובג'ימייל",
  "description": "הסרת תוצאות ממומנות מחיפוש גוגל ופרסומות מ-Gmail (אימיילים ממומנים ובאנרים) | Removes ads from Google Search & Gmail",
  "version": "1.2.1",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://raw.githubusercontent.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.google.com/*", "*://www.google.co.il/*", "*://www.google.co.uk/*", "*://www.google.de/*", "*://www.google.fr/*", "*://www.google.es/*", "*://www.google.ca/*", "*://www.google.com.au/*", "*://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon_16.png",
    "32": "icon_32.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  }
}
