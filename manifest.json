{
  "manifest_version": 3,
  "name": "חוסם פרסומות בחיפוש גוגל",
  "description": "הסרת תוצאות ממומנות ופרסומות מחיפוש גוגל באופן אוטומטי | Removes sponsored results and ads from Google Search",
  "version": "1.0",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://www.google.com/*", "*://www.google.co.il/*", "*://www.google.co.uk/*", "*://www.google.de/*", "*://www.google.fr/*", "*://www.google.es/*", "*://www.google.ca/*", "*://www.google.com.au/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon_16.png",
    "32": "icon_32.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  }
}
